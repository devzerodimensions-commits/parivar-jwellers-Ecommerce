# Base URL of the backend API.
# In dev you can leave this as "/api" and let Vite proxy it to :5000.
# In production set it to your deployed API origin, e.g. https://api.jewelly.com/api
VITE_API_URL=/api

# Phone number used by every "Call for Enquiry" button (tel: dialer).
# Use international format. Change here to update it everywhere.
VITE_ENQUIRY_PHONE=+919876543210

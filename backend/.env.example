# Copy to .env for local dev, or set these in the Render dashboard for production.

# ---- Server ----
NODE_ENV=development
PORT=5000
# Frontend origin. In production set to your live URL, e.g.
# https://parivarjewellers.onrender.com
CLIENT_URL=http://localhost:5173

# ---- Database ----
# Local: mongodb://127.0.0.1:27017/jewelly
# Atlas: mongodb+srv://<user>:<pass>@<cluster>.mongodb.net/jewelly?retryWrites=true&w=majority
MONGO_URI=mongodb://127.0.0.1:27017/jewelly

# ---- Auth ----
JWT_SECRET=replace_with_a_long_random_secret
JWT_EXPIRES_IN=7d

# ---- Branding ----
SITE_NAME=Parivar Jewellers

# ---- Email (SMTP) — optional. Blank = password-reset link shown on screen. ----
# Brevo example: smtp-relay.brevo.com / 587 / <login> / <smtp-key>
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM="Parivar Jewellers <no-reply@parivarjewellers.com>"

# ---- Public base URL of API (used for sitemap URLs) ----
API_URL=http://localhost:5000

# ---- Default admin (created on first boot / by the seed script) ----
ADMIN_NAME=Store Admin
ADMIN_EMAIL=admin@parivarjewellers.com
ADMIN_PASSWORD=Admin@123
